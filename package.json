{
  "name": "ai-otdel-workspace",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "start": "npm run start -w web",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run api:free-port && node scripts/pg-ping.mjs && npm run start:dev -w tenant-api",
    "dev:full": "concurrently -n api,web -c blue,cyan \"npm run dev:api\" \"npm run dev:web\"",
    "db:reset": "node scripts/reset-db.mjs",
    "api:free-port": "lsof -ti :3333 | xargs kill 2>/dev/null || true",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:up:detached": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "postgres:up": "docker compose up postgres -d",
    "postgres:stop": "docker compose stop postgres"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
