PORT=3333
# Путь к JSON-снимку состояния (создаётся автоматически).
DATA_PATH=data/state.json

# Секрет супер-админки (заголовок X-Super-Admin-Key). Должен совпадать с NEXT_PUBLIC_SUPER_ADMIN_KEY во фронте.
SUPER_ADMIN_KEY=change-me-super-secret

# Опционально: если задан, все запросы /v1/tenant/* требуют X-Api-Key.
# TENANT_API_KEY=

# Основной провайдер ответов ИИ (Anthropic).
ANTHROPIC_API_KEY=
# Модель по умолчанию (можно переопределить).
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Запасные провайдеры (опционально).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# CORS через запятую; если пусто — разрешены все origin (удобно для локальной разработки).
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
