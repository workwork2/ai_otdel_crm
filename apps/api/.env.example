PORT=3333

# --- PostgreSQL (обязательно) ---
# Локально: сначала поднимите БД. Из корня репозитория: npm run postgres:up
# (тот же user/pass/db, что в docker-compose). Ошибка ECONNREFUSED = Postgres не слушает порт.
DATABASE_URL=postgresql://linearize:linearize@localhost:5432/linearize
# Полный сброс данных (tenants + platform): из корня репозитория CONFIRM_RESET=1 npm run db:reset
# При старте API применяются миграции из apps/api/drizzle (run-migrations.ts). Если таблицы уже были от TypeORM, без журнала drizzle — один раз делается baseline.
# Альтернатива в CI: npm run db:migrate -w api в отдельном Job.
# Отключить migrate на поде (K8s): RUN_MIGRATIONS=false — тогда схему накатывает отдельный init-контейнер/Job.
RUN_MIGRATIONS=true
#
# Продакшен: tenants + platform_settings + platform_admins хранятся только в PostgreSQL; перед остановкой процесса
# Nest: SIGTERM → onModuleDestroy (flush в StoreService) → затем onApplicationShutdown (закрытие пула в DatabaseModule).

# Подпись JWT для входа главного админа в Super Admin
JWT_SECRET=change-me-long-random-string

# Опционально: создать первого админа при старте (если не используете /v1/auth/platform/bootstrap)
# PLATFORM_ADMIN_EMAIL=admin@example.com
# PLATFORM_ADMIN_PASSWORD=your-secure-password

# Секрет супер-админки (заголовок X-Super-Admin-Key). Можно совместить с JWT.
SUPER_ADMIN_KEY=change-me-super-secret

# Опционально: если задан, все запросы /v1/tenant/* требуют X-Api-Key.
# TENANT_API_KEY=

# ИИ: по умолчанию сначала Google Gemini, затем Anthropic. Порядок: AI_PRIMARY_PROVIDER=gemini | anthropic
# В dev при старте в консоли: [env] AI keys loaded: GEMINI_API_KEY=true/false — если false, .env не подхватился или ключ пустой.
AI_PRIMARY_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Публичный URL клиентской панели (для одноразовых ссылок «Войти как» из супер-админки)
USER_PORTAL_PUBLIC_URL=http://localhost:3000

# --- SMTP — общий сервер для всех tenants (fallback). Свой SMTP можно задать в UI: Интеграции → Email → Настроить. ---
# SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="AI Отдел <noreply@example.com>"
