# Nest API (клиенты, QA, ИИ, поддержка). Без NEXT_PUBLIC_* не попадёт в браузер.
NEXT_PUBLIC_API_URL="http://localhost:3333"

# После сброса БД увеличьте — сбросит сессии в этой вкладке.
# NEXT_PUBLIC_SESSION_EPOCH=1

# Опционально: TENANT_API_KEY на API.
# NEXT_PUBLIC_TENANT_API_KEY=""

# NEXT_PUBLIC_DEMO_TENANT_ID=

# Запасной путь «Доработать с ИИ» из браузера.
# NEXT_PUBLIC_GEMINI_API_KEY=""
# NEXT_PUBLIC_GEMINI_MODEL="gemini-2.5-flash"

# Рассылка /outreach: локальный превью-план без API (по умолчанию вкл.). Выключить: =0
NEXT_PUBLIC_OUTREACH_FORCE_LOCAL_PLAN=1

NEXT_PUBLIC_APP_ORIGIN="http://localhost:3000"

NEXT_PUBLIC_SUPPORT_EMAIL="admin@example.com"

# Control Plane теперь на том же origin: /platform. Оставьте пустым — в коде подставится /platform.
# Если админка на другом домене — полный URL без хвостового слэша.
# NEXT_PUBLIC_SUPER_APP_URL="https://admin.example.com"

# Запросы к /v1/super/* с заголовком (как в старой супер-админке).
NEXT_PUBLIC_SUPER_ADMIN_KEY="change-me-super-secret"
