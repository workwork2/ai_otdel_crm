# Nest API (общее состояние: клиенты, QA, мозг ИИ, чат поддержки). Без префикса не попадёт в браузер.
NEXT_PUBLIC_API_URL="http://localhost:3333"

# Увеличьте число после сброса БД (npm run db:reset) — сбросит сессию в браузере для этой вкладки.
# NEXT_PUBLIC_SESSION_EPOCH=1

# Опционально: если на API включён TENANT_API_KEY.
# NEXT_PUBLIC_TENANT_API_KEY=""

# После входа на /login tenant id хранится в sessionStorage. Демо-ID в env не обязателен.
# NEXT_PUBLIC_DEMO_TENANT_ID=

# Запасной путь «Доработать с ИИ» из браузера, если ответ API пустой/ошибка. В клиентском коде видны только переменные NEXT_PUBLIC_*.
# Скопируйте сюда ключ из apps/api/.env (GEMINI_API_KEY) или заведите отдельный ключ для фронта.
# NEXT_PUBLIC_GEMINI_API_KEY=""

# Модель Gemini для запасного вызова из браузера (как GEMINI_MODEL на API). По умолчанию gemini-2.5-flash.
# NEXT_PUBLIC_GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Демо tenant id для проверки блокировки чата без impersonation (должен совпадать с id в super-admin).
# NEXT_PUBLIC_DEMO_TENANT_ID=""

# Почта администратора CRM-панели (ссылка «Техподдержка» в боковом меню).
NEXT_PUBLIC_SUPPORT_EMAIL="admin@example.com"

# URL второго сайта — супер-админки (порт 3001 локально). Ссылка в баннере God mode.
NEXT_PUBLIC_SUPER_APP_URL="http://localhost:3001"

# В проде супер-админку защитить middleware (сессия владельца, IP allowlist, Basic Auth).
