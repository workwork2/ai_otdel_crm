# URL панели клиентов (первый сайт, порт 3000 локально). «Панель клиента» и impersonation.
NEXT_PUBLIC_USER_APP_URL="http://localhost:3000"

# Тот же Nest API, что и у user-dashboard.
NEXT_PUBLIC_API_URL="http://localhost:3333"

# Должен совпадать с SUPER_ADMIN_KEY в apps/api/.env (только для внутренней сети / демо).
NEXT_PUBLIC_SUPER_ADMIN_KEY="change-me-super-secret"

# В проде — OAuth / секрет для доступа только к этому приложению; не светите SUPER ключ в публичном фронте.
