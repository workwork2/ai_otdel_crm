# Опционально (редко): если понадобится ссылаться на CRM с фронта супер-админки. В шапке консоли ссылка на CRM убрана —
# вход в панель клиента только через «Все организации» → «Войти как» (одноразовый URL с API).
# NEXT_PUBLIC_USER_APP_URL="http://localhost:3000"

# Тот же Nest API, что и у user-dashboard.
NEXT_PUBLIC_API_URL="http://localhost:3333"

# После db:reset увеличьте — выйдет сессия супер-админки в браузере.
# NEXT_PUBLIC_SESSION_EPOCH=1

# Раньше: ключ в браузере обходил вход. Сейчас панель требует JWT после /login; этот ключ не используется на фронте.
# На API SUPER_ADMIN_KEY по-прежнему опционален для машинных вызовов (без отправки ключа из браузера).
# NEXT_PUBLIC_SUPER_ADMIN_KEY=

# После первого запуска API с PostgreSQL откройте /login: bootstrap главного админа или обычный вход.
